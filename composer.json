{
  "name": "oriacall/sdk",
  "description": "PHP SDK for the Oriacall Developer API.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "oriacall",
    "sdk",
    "api",
    "php",
    "laravel"
  ],
  "require": {
    "php": "^8.2",
    "ext-curl": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Oriacall\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Oriacall\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test:unit": "phpunit",
    "validate": "composer validate --strict"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
